# Local development default (SQLite)
DATABASE_URL=sqlite:///./local.db

# Shared secret used by the frontend server when calling protected API routes.
# Leave unset locally if you do not want request signing.
API_SHARED_SECRET=

# Comma-separated list of frontend origins allowed by CORS.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production (Vercel + Neon) example:
# DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>/<dbname>?sslmode=require
# API_SHARED_SECRET=<random-long-secret>
# CORS_ALLOWED_ORIGINS=https://<your-frontend>.vercel.app,https://<your-custom-domain>
